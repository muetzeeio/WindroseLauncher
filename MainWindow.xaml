<Window x:Class="WindroseLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windrose Mod Launcher"
        Width="1280"
        Height="800"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        AllowsTransparency="False"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="HitButton" TargetType="Button">
            <Setter Property="Background" Value="#01000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="6"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#11FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#22000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Fill">
        <Canvas Width="1536" Height="1024">
            <!-- 1:1 Mockup Skin -->
            <Image Source="Assets/launcher_mockup.png"
               Canvas.Left="0"
               Canvas.Top="0"
               Width="1536"
               Height="1024"
               Stretch="Fill"/>

            <!-- Dynamic overlays: cover baked mockup text and draw real values -->
            <!-- Path text overlay -->
            <Border Canvas.Left="58" Canvas.Top="291" Width="1096" Height="48" Background="#050505" CornerRadius="3"/>
            <TextBlock x:Name="PathText"
                   Canvas.Left="78"
                   Canvas.Top="303"
                   Width="1060"
                   Height="28"
                   Foreground="#EDEDED"
                   FontSize="21"
                   TextTrimming="CharacterEllipsis"/>

            <!-- Status text/icon overlay -->
            <Border x:Name="StatusIconCover"
                Canvas.Left="60"
                Canvas.Top="438"
                Width="148"
                Height="150"
                Background="#232323"
                Opacity="1"
                CornerRadius="7"/>
            <Border Canvas.Left="205" Canvas.Top="470" Width="235" Height="95" Background="#242424" Opacity="0.96" CornerRadius="4"/>
            <TextBlock x:Name="StatusIconOverlay"
                   Canvas.Left="74"
                   Canvas.Top="446"
                   Width="128"
                   Height="128"
                   Text="🛡"
                   FontSize="102"
                   Foreground="#5FB044"/>
            <TextBlock x:Name="StatusTitleOverlay"
                   Canvas.Left="220"
                   Canvas.Top="482"
                   Width="240"
                   Height="42"
                   Text="KEIN PFAD"
                   FontSize="34"
                   FontWeight="Bold"
                   Foreground="#FFB000"/>
            <TextBlock x:Name="StatusSubOverlay"
                   Canvas.Left="220"
                   Canvas.Top="526"
                   Width="250"
                   Height="30"
                   Text="Bitte Installationspfad wählen"
                   FontSize="21"
                   Foreground="#CFCFCF"
                   TextTrimming="CharacterEllipsis"/>


            <!-- Game status overlay -->
            <Border Canvas.Left="150" Canvas.Top="708" Width="235" Height="62" Background="#252525" Opacity="0.96" CornerRadius="4"/>
            <TextBlock Canvas.Left="154"
                   Canvas.Top="709"
                   Width="210"
                   Height="32"
                   Text="Windrose"
                   FontSize="27"
                   FontWeight="Bold"
                   Foreground="#F2F2F2"/>
            <TextBlock x:Name="GameStatusOverlay"
                   Canvas.Left="154"
                   Canvas.Top="743"
                   Width="250"
                   Height="30"
                   Text="Bereit zum Start"
                   FontSize="22"
                   Foreground="#5CFF5C"
                   TextTrimming="CharacterEllipsis"/>

            <!-- Log overlay -->
            <Border Canvas.Left="536" Canvas.Top="777" Width="938" Height="106" Background="#050505" CornerRadius="3"/>
            <RichTextBox x:Name="RealLogBox"
                 Canvas.Left="536"
                 Canvas.Top="777"
                 Width="938"
                 Height="106"
                 Background="#050505"
                 Foreground="#61A6FF"
                 BorderBrush="#050505"
                 BorderThickness="0"
                 FontFamily="Consolas"
                 FontSize="15"
                 Padding="10"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"/>


            <!-- Drag area -->
            <Border Canvas.Left="0"
                Canvas.Top="0"
                Width="1260"
                Height="56"
                Background="#01000000"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>

            <!-- Window buttons -->
            <Button Canvas.Left="1295" Canvas.Top="0" Width="74" Height="56" Style="{StaticResource HitButton}" Click="Minimize_Click" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Button Canvas.Left="1374" Canvas.Top="0" Width="77" Height="56" Style="{StaticResource HitButton}" Click="Maximize_Click" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Button Canvas.Left="1456" Canvas.Top="0" Width="78" Height="56" Style="{StaticResource HitButton}" Click="Exit_Click" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Functional hit zones matching the mockup -->
            <Button Canvas.Left="1165" Canvas.Top="287" Width="280" Height="58" Style="{StaticResource HitButton}" Click="ChooseFolder_Click"/>

            <Button Canvas.Left="550" Canvas.Top="443" Width="445" Height="108" Style="{StaticResource HitButton}" Click="PlayVanilla_Click"/>
            <Button Canvas.Left="1015" Canvas.Top="443" Width="445" Height="108" Style="{StaticResource HitButton}" Click="PlayMods_Click"/>

            <Button Canvas.Left="550" Canvas.Top="574" Width="445" Height="100" Style="{StaticResource HitButton}" Click="InstallMods_Click"/>
            <Button Canvas.Left="1015" Canvas.Top="574" Width="445" Height="100" Style="{StaticResource HitButton}" Click="RemoveMods_Click"/>

            <Button Canvas.Left="40" Canvas.Top="936" Width="187" Height="64" Style="{StaticResource HitButton}" Click="Settings_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Button Canvas.Left="236" Canvas.Top="936" Width="135" Height="64" Style="{StaticResource HitButton}" Click="About_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Button Canvas.Left="1295" Canvas.Top="936" Width="200" Height="64" Style="{StaticResource HitButton}" Click="Exit_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        </Canvas>
    </Viewbox>
</Window>