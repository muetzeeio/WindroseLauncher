<Window x:Class="WindroseLauncher.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen" Width="620" Height="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="Transparent" AllowsTransparency="True" WindowStyle="None"
        FontFamily="Segoe UI">
    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#242424" Offset="0"/>
            <GradientStop Color="#101010" Offset="0.55"/>
            <GradientStop Color="#1D1D1D" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CardBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#303030" Offset="0"/>
            <GradientStop Color="#1C1C1C" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="OrangeBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF8C2F" Offset="0"/>
            <GradientStop Color="#C94F00" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="DarkButtonBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#454545" Offset="0"/>
            <GradientStop Color="#242424" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="{StaticResource WindowBrush}" CornerRadius="10" BorderBrush="#383838" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#1B1B1B" CornerRadius="10,10,0,0" BorderBrush="#0B0B0B" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="22,0,0,0">
                        <TextBlock Text="⚙" FontSize="25" Foreground="#D88A2E" Margin="0,0,12,0"/>
                        <TextBlock Text="Einstellungen" FontSize="22" FontWeight="SemiBold" Foreground="#F2F2F2"/>
                    </StackPanel>
                    <Button Width="58" Height="56" HorizontalAlignment="Right" Content="×" FontSize="30" Foreground="#F2F2F2" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Close_Click"/>
                </Grid>
            </Border>
            <Grid Grid.Row="1" Margin="26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
            Background="{StaticResource CardBrush}"
            CornerRadius="9"
            BorderBrush="#444"
            BorderThickness="1"
            Padding="24">

                    <StackPanel>

                        <TextBlock Text="Launcher Update"
                       Margin="0,-10,0,0"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#FFE0A4" Height="38"/>

                        <TextBlock Text="Prüft GitHub Releases und zeigt an, ob eine neue Version verfügbar ist."
                       Margin="0,10,0,0"
                       FontSize="16"
                       Foreground="#CFCFCF"
                       TextWrapping="Wrap" Height="42"/>
                        <Border
                    Background="#151515"
                    BorderBrush="#222"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16" Height="113">

                            <StackPanel>

                                <TextBlock Text="Status"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#F2F2F2"/>

                                <TextBlock x:Name="StatusText"
                               Text="Noch nicht geprüft"
                               Margin="0,8,0,0"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#61A6FF"/>

                                <TextBlock x:Name="VersionText"
                               Text="Aktuelle Version: v1.0.0"
                               Margin="0,6,0,0"
                               FontSize="15"
                               Foreground="#AAAAAA"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1" VerticalAlignment="Bottom" Margin="0,0,0,0" Height="50">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="CheckButton"
                Grid.Column="0"
                Height="44"
                Content="Check Version"
                FontSize="16"
                Background="{StaticResource DarkButtonBrush}"
                Style="{StaticResource ModernButton}"
                Click="CheckButton_Click"/>

                    <Button x:Name="DownloadButton"
                Grid.Column="2"
                Height="44"
                Content="Update laden"
                FontSize="16"
                Background="{StaticResource OrangeBrush}"
                Style="{StaticResource ModernButton}"
                Visibility="Collapsed"
                Click="DownloadButton_Click"/>

                    <Button Grid.Column="4"
                Height="44"
                Content="Schließen"
                FontSize="16"
                Background="{StaticResource DarkButtonBrush}"
                Style="{StaticResource ModernButton}"
                Click="Close_Click"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>